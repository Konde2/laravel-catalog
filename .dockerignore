# Compiled assets
*.log
npm-debug.log
yarn-error.log

# Testing
.phpunit.result.cache
coverage/

# Docker (не включать конфиги Docker в контекст сборки)
docker-compose.override.yml
.docker/

# OS
.DS_Store
Thumbs.db

# Uploads (if any)
storage/app/public/*
!storage/app/public/.gitignore
